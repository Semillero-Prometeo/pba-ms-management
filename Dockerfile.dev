FROM node:22-slim AS base

WORKDIR /usr/src/app

# 1. Sistema — capa que casi nunca cambia
RUN apt-get update \
  && apt-get install -y --no-install-recommends procps \
  && rm -rf /var/lib/apt/lists/*

# 2. Dependencias — solo se reinstalan si cambia package.json o package-lock.json
COPY --chown=node:node package*.json ./
RUN npm ci --prefer-offline

# 3. Código fuente — la capa que cambia con más frecuencia
COPY --chown=node:node . .

# Exponer el puerto de debugging
EXPOSE 9233